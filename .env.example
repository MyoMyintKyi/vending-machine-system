# Optional application metadata
APP_NAME=VendingMachine
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Required database connection settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vending_machine
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Required session setting for web authentication
SESSION_NAME=vending_machine_session

# Required JWT settings for API authentication
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_TTL=3600