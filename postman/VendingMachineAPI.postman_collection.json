          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products?page={{page}}&per_page={{per_page}}&sort={{sort}}&direction={{direction}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "per_page",
                  "value": "{{per_page}}"
                },
                {
                  "key": "sort",
                  "value": "{{sort}}"
                },
                {
                  "key": "direction",
                  "value": "{{direction}}"
                }
              ]
            }
          },
          "response": []
